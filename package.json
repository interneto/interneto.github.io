{
  "name": "interneto-website",
  "packageManager": "pnpm@10.12.2+sha256.07b2396c6c99a93b75b5f9ce22be9285c3b2533c49fec51b349d44798cf56b82",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vitepress dev docs/",
    "docs:build": "vitepress build docs/",
    "build": "vitepress build docs/",
    "build:prod": "pnpm clean && pnpm install && vitepress build docs/",
    "preview": "vitepress preview docs/",
    "format": "prettier -w --cache --check .",
    "clean": "rimraf dist docs/.vitepress/dist docs/.vitepress/cache",
    "convert": "node ./scripts/convert-interneto-links-to-markdown.js",
    "og:dev": "x-satori -t ./docs/.vitepress/hooks/Template.vue -c ./docs/.vitepress/hooks/satoriConfig.ts --dev"
  },
  "dependencies": {
    "@fmhy/colors": "^0.0.11",
    "@fmhy/components": "^0.0.3",
    "@headlessui/vue": "^1.7.23",
    "@resvg/resvg-js": "^2.6.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "consola": "^3.4.2",
    "feed": "^5.2.1",
    "mark.js": "^8.11.1",
    "minisearch": "^7.2.0",
    "nprogress": "^0.2.0",
    "pathe": "^2.0.3",
    "reka-ui": "^2.9.6",
    "sharp": "^0.34.5",
    "unocss": "66.6.8",
    "vitepress": "^1.6.4",
    "vue": "^3.5.33",
    "x-satori": "^0.4.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/twemoji": "^1.2.5",
    "@types/node": "^25.6.0",
    "@types/nprogress": "^0.2.3",
    "@vue/compiler-sfc": "^3.5.33",
    "floating-vue": "^5.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-pkgsort": "^0.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.10",
    "vite-plugin-optimize-exclude": "^0.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-terminal": "^1.4.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search",
        "search-insights"
      ],
      "allowedVersions": {
        "vite-plugin-pwa>vite": "8",
        "vite-plugin-terminal>vite": "8",
        "@fmhy/components>typescript": "6"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "vue-demi",
      "workerd"
    ]
  }
}
