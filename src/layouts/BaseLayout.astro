---
import SiteFooter from '../components/SiteFooter.astro';
import VPNavBar from '../components/VPNavBar.astro';

interface Props {
  title: string;
  extraStyles?: string[];
  hideFooter?: boolean;
  hideHeader?: boolean;
}

const { title, extraStyles = [], hideFooter = false, hideHeader = false } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script is:inline>
    (function () {
      try {
        const storedTheme = localStorage.getItem('theme-preference');
        const legacyTheme = localStorage.getItem('vitepress-theme-appearance');
        const preferredTheme = storedTheme || legacyTheme;
        const theme = preferredTheme === 'dark' || preferredTheme === 'light'
          ? preferredTheme
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        const root = document.documentElement;
        root.setAttribute('data-theme', theme);
        root.classList.toggle('dark', theme === 'dark');
        root.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
      } catch (_) {
        document.documentElement.setAttribute('data-theme', 'light');
        document.documentElement.classList.remove('dark');
        document.documentElement.style.colorScheme = 'light';
      }
    })();
  </script>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
  <link rel="stylesheet" href={`${BASE}styles/vitepress-base.css`} />
  <link rel="stylesheet" href={`${BASE}styles/base-styles.css`} />
  <link rel="stylesheet" href={`${BASE}styles/vp-shell.css`} />
  {extraStyles.map(href => <link rel="stylesheet" href={`${BASE}${href.replace(/^\//, '')}`} />)}
</head>
<body class="vp-shell-body">
  {!hideHeader && <VPNavBar />}
  <slot />
  {!hideFooter && <SiteFooter />}
  <script>
    import '../scripts/theme-manager.ts';
  </script>
</body>
</html>
