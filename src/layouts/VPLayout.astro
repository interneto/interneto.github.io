---
import VPNavBar from '../components/VPNavBar.astro';
import VPSidebar from '../components/VPSidebar.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hasSidebar?: boolean;
  hideSidebar?: boolean;
  hideFooter?: boolean;
  extraStyles?: string[];
}

const {
  title,
  description = 'Interneto - Rediscover the Internet',
  ogImage,
  hasSidebar = true,
  hideSidebar = false,
  hideFooter = false,
  extraStyles = []
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const pathname = Astro.url.pathname;
const shouldShowSidebar = hasSidebar && !hideSidebar;
const canonicalUrl = new URL(pathname, 'https://interneto.github.io').href;
const ogImageUrl = ogImage ?? `https://interneto.github.io/icon.png`;
---

<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <script is:inline>
    // Theme detection and application
    (function () {
      try {
        const storedTheme = localStorage.getItem('theme-preference');
        const legacyTheme = localStorage.getItem('vitepress-theme-appearance');
        const preferredTheme = storedTheme || legacyTheme;
        const isDark = preferredTheme === 'dark' ||
          (preferredTheme !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        
        const html = document.documentElement;
        html.setAttribute('data-theme', isDark ? 'dark' : 'light');
        html.classList.toggle('dark', isDark);
        html.style.colorScheme = isDark ? 'dark' : 'light';
      } catch (_) {
        document.documentElement.setAttribute('data-theme', 'light');
        document.documentElement.classList.remove('dark');
        document.documentElement.style.colorScheme = 'light';
      }
    })();

    // Detect macOS
    document.documentElement.classList.toggle('mac', /Mac|iPhone|iPad/i.test(navigator.platform));
  </script>
  
  <title>{title} • Rediscover the Internet</title>
  <link rel="canonical" href={canonicalUrl} />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Interneto" />
  <meta property="og:title" content={`${title} • Interneto`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <!-- Twitter/X card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} • Interneto`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="icon" type="image/x-icon" href={`${BASE}favicon.ico`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${BASE}favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${BASE}favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${BASE}apple-touch-icon.png`} />
  <link rel="manifest" href={`${BASE}site.webmanifest`} />
  <link rel="alternate" type="application/rss+xml" title="Interneto Posts" href={`${BASE}rss.xml`} />
  <link rel="stylesheet" href={`${BASE}styles/vitepress-base.css`} />
  <link rel="stylesheet" href={`${BASE}styles/vp-layout.css`} />
  <link rel="stylesheet" href={`${BASE}styles/vp-shell.css`} />
  {extraStyles.map(href => <link rel="stylesheet" href={`${BASE}${href.replace(/^\//, '')}`} />)}
  <script is:inline define:vars={{ shouldShowSidebar, pathname }}>
    // Expose for client-side scripts
    window.__VPConfig = {
      shouldShowSidebar,
      pathname,
      base: '/',
    };
  </script>
</head>
<body class="vp-shell-body">
  <div id="app" class="Layout">
    <a href="#VPContent" class="VPSkipLink visually-hidden">Skip to content</a>
    
    <VPNavBar title="Interneto" />
    
    {shouldShowSidebar && <VPSidebar currentPath={pathname} />}
    {shouldShowSidebar && <button id="vpSidebarTrigger" class="vp-sidebar-mobile-trigger" aria-controls="vpSidebar" aria-expanded="false">☰ Menu</button>}
    {shouldShowSidebar && <button id="vpMobileSidebarBackdrop" class="vp-mobile-sidebar-backdrop" aria-label="Close mobile menu"></button>}
    
    <main id="VPContent" class={`VPContent ${shouldShowSidebar ? 'with-sidebar' : ''}`}>
      <slot />
    </main>

    {!hideFooter && <SiteFooter />}
  </div>

  <script>
    import '../scripts/theme-manager.ts';
  </script>

  <script is:inline>
    (() => {
      const root = document.documentElement;
      const hamburger = document.getElementById('vpNavHamburger');
      const mobileNavPanel = document.getElementById('vpMobileNavPanel');
      const navOverlay = document.getElementById('vpNavOverlay');
      const sidebar = document.getElementById('vpSidebar');
      const sidebarTrigger = document.getElementById('vpSidebarTrigger');
      const sidebarBackdrop = document.getElementById('vpMobileSidebarBackdrop');

      /* ── Sidebar ── */
      function setSidebarOpen(open) {
        if (!sidebar) return;
        root.classList.toggle('vp-mobile-sidebar-open', open);
        sidebar.setAttribute('aria-hidden', open ? 'false' : 'true');
        if (sidebarTrigger) {
          sidebarTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
      }

      /* ── Mobile nav ── */
      function setNavOpen(open) {
        root.classList.toggle('vp-mobile-nav-open', open);
        if (hamburger) hamburger.setAttribute('aria-expanded', open ? 'true' : 'false');
        if (mobileNavPanel) mobileNavPanel.setAttribute('aria-hidden', open ? 'false' : 'true');
        if (navOverlay) navOverlay.setAttribute('aria-hidden', open ? 'false' : 'true');
      }

      if (hamburger) {
        hamburger.addEventListener('click', () => {
          const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
          setSidebarOpen(false);
          setNavOpen(!isOpen);
        });
      }

      /* Close mobile nav when a nav link is clicked */
      if (mobileNavPanel) {
        mobileNavPanel.addEventListener('click', (e) => {
          if (e.target instanceof HTMLElement && e.target.closest('a')) {
            setNavOpen(false);
          }
        });
      }

      /* Close mobile nav when overlay is clicked */
      if (navOverlay) {
        navOverlay.addEventListener('click', () => setNavOpen(false));
      }

      /* Sidebar trigger and backdrop */
      if (sidebarTrigger) {
        sidebarTrigger.addEventListener('click', () => {
          const isOpen = sidebarTrigger.getAttribute('aria-expanded') === 'true';
          setNavOpen(false);
          setSidebarOpen(!isOpen);
        });
      }

      if (sidebarBackdrop) {
        sidebarBackdrop.addEventListener('click', () => setSidebarOpen(false));
      }

      /* Close both menus on Escape */
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          setNavOpen(false);
          setSidebarOpen(false);
        }
      });

      /* Close mobile nav when viewport becomes wide enough (resize) */
      const desktopMq = window.matchMedia('(min-width: 48rem)');
      function handleResize(mq) {
        if (mq.matches) setNavOpen(false);
      }
      desktopMq.addEventListener('change', handleResize);
    })();
  </script>

  <script is:inline>
    /* Keyboard shortcuts: T = toggle theme, / = focus search */
    document.addEventListener('keydown', (e) => {
      const tag = document.activeElement?.tagName ?? '';
      if (['INPUT', 'TEXTAREA', 'SELECT'].includes(tag)) return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;

      if (e.key === 't' || e.key === 'T') {
        e.preventDefault();
        document.getElementById('themeToggle')?.click();
      } else if (e.key === '/') {
        e.preventDefault();
        const search =
          document.getElementById('searchInput') ||
          document.getElementById('categorySidebarSearch');
        if (search instanceof HTMLElement) {
          search.focus();
          search.scrollIntoView({ block: 'nearest' });
        }
      }
    });
  </script>
</body>
</html>
