---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  heading: string;
  subtitle: string;
  installerHref: string;
  installerLabel?: string;
  extraStyles?: string[];
  searchPlaceholder?: string;
}

const {
  title,
  heading,
  subtitle,
  installerHref,
  installerLabel = 'Go to Installer',
  extraStyles = [],
  searchPlaceholder = 'Search...',
} = Astro.props;
---
<BaseLayout title={title} extraStyles={['styles/os-compatibility.css', ...extraStyles]}>
  <div class="container">
    <header class="page-header">
      <h1>{heading}</h1>
    </header>
    <p class="subtitle">{subtitle}</p>
    <div class="page-controls controls">
      <div class="page-controls-panel">
        <div class="search-box">
          <input type="search" id="searchInput" placeholder={searchPlaceholder} />
        </div>
      </div>
      <slot name="controls" />
    </div>
    <slot name="legend" />
    <slot />
    <slot name="extra" />
  </div>
  <slot name="script" />
</BaseLayout>
