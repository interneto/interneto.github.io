---
export interface Feature {
  icon?: string;
  title: string;
  details?: string;
  link?: string;
}

interface Props {
  features: Feature[];
  title?: string;
}

const { features, title } = Astro.props;
---

<section class="vp-features">
  <div class="vp-features-container">
    {title && <h2 class="vp-features-title">{title}</h2>}
    <div class="vp-features-grid">
      {features.map((feature) => (
        <div class="vp-feature-item">
          {feature.link ? (
            <a href={feature.link} class="vp-feature-link">
              {feature.icon && <div class="vp-feature-icon">{feature.icon}</div>}
              <h3 class="vp-feature-title">{feature.title}</h3>
              {feature.details && <p class="vp-feature-details">{feature.details}</p>}
            </a>
          ) : (
            <>
              {feature.icon && <div class="vp-feature-icon">{feature.icon}</div>}
              <h3 class="vp-feature-title">{feature.title}</h3>
              {feature.details && <p class="vp-feature-details">{feature.details}</p>}
            </>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
