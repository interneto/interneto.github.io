---
import InstallerLayout from '../layouts/InstallerLayout.astro';
import CommandFooter from './CommandFooter.astro';
import UnifiedControls from './UnifiedControls.astro';

interface SelectOption {
  value: string;
  label: string;
}

export interface Props {
  title: string;
  heading: string;
  extraStyles?: string[];
  searchPlaceholder: string;
  options?: SelectOption[];
  optionsId?: string;
  optionsPlaceholder?: string;
  showFossToggle?: boolean;
  showFileInput?: boolean;
  showInternalToggle?: boolean;
  browserSelectionOptions?: Array<{ value: string; label: string }>;
  useForm?: boolean;
  formId?: string;
}

const {
  title,
  heading,
  extraStyles = [],
  searchPlaceholder,
  options = [],
  optionsId = 'optionsSelect',
  optionsPlaceholder = '⚙️ Options',
  showFossToggle = true,
  showFileInput = true,
  showInternalToggle = false,
  browserSelectionOptions = [],
  useForm = false,
  formId,
} = Astro.props;
---

<InstallerLayout
  title={title}
  heading={heading}
  extraStyles={extraStyles}
>
  <section class="package-section installer-page-section">
    {useForm ? (
      <form id={formId}>
        <div class="container installer-surface">
          <slot name="selectors" />
          <UnifiedControls
            searchPlaceholder={searchPlaceholder}
            options={options}
            optionsId={optionsId}
            optionsPlaceholder={optionsPlaceholder}
            showFossToggle={showFossToggle}
            showFileInput={showFileInput}
            showInternalToggle={showInternalToggle}
            browserSelectionOptions={browserSelectionOptions}
          />
        </div>
        <slot name="content" />
      </form>
    ) : (
      <>
        <div class="container installer-surface">
          <slot name="selectors" />
          <UnifiedControls
            searchPlaceholder={searchPlaceholder}
            options={options}
            optionsId={optionsId}
            optionsPlaceholder={optionsPlaceholder}
            showFossToggle={showFossToggle}
            showFileInput={showFileInput}
            showInternalToggle={showInternalToggle}
            browserSelectionOptions={browserSelectionOptions}
          />
        </div>
        <slot name="content" />
      </>
    )}
  </section>

  <slot name="footer" />
  <CommandFooter />
</InstallerLayout>