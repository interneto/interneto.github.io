---
import { isToolboxRoute } from '../scripts/toolbox-routes';
import Icon from './Icon.astro';
import type { IconName } from './Icon.astro';

interface NavLink {
  text: string;
  link: string;
  icon: IconName;
}

export interface Props {
  title?: string;
  links?: NavLink[];
}

const { title = 'Interneto', links = [] } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const pathname = Astro.url.pathname;

const defaultLinks: NavLink[] = [
  { text: 'Categories', link: `${BASE}categories/`, icon: 'categories' },
  { text: 'Map of Links', link: `${BASE}map/`, icon: 'map' },
  { text: 'Toolbox Installer', link: `${BASE}toolbox-installer/`, icon: 'toolbox' },
  { text: 'Posts', link: `${BASE}posts/`, icon: 'posts' },
  { text: 'About', link: `${BASE}about/`, icon: 'about' },
];

const navLinks = links.length > 0 ? links : defaultLinks;

const isActive = (link: string) => {
  if (link === `${BASE}toolbox-installer/`) {
    return isToolboxRoute(pathname, BASE);
  }
  if (link === `${BASE}` || link === '/') {
    return pathname === BASE || pathname === '/';
  }
  return pathname.startsWith(link);
};
---

<header class="vp-nav">
  <div class="vp-nav-wrapper">
    <div class="vp-nav-container">
      <!-- Brand (always visible) -->
      <a class="vp-nav-brand" href={`${BASE}`}>
        <img src={`${BASE}icon.png`} alt="Interneto" class="vp-nav-icon-img" />
        <span class="vp-nav-brand-text">{title}</span>
      </a>

      <!-- Desktop navigation (hidden on mobile, shown at ≥768px via CSS) -->
      <nav class="vp-nav-menu" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            class={`vp-nav-menu-link ${isActive(link.link) ? 'active' : ''}`}
            href={link.link}
            target={link.link.startsWith('http') ? '_blank' : undefined}
            rel={link.link.startsWith('http') ? 'noreferrer' : undefined}
          >
            <span class="vp-nav-menu-link-content">
              <Icon name={link.icon} class="vp-nav-link-icon" />
              <span>{link.text}</span>
            </span>
          </a>
        ))}
      </nav>

      <!-- Right actions: theme toggle (always visible) + hamburger (hidden at ≥768px) -->
      <div class="vp-nav-actions">
        <button
          type="button"
          id="themeToggle"
          data-theme-toggle
          class="vp-theme-toggle"
          aria-label="Switch theme"
          title="Toggle theme"
        >
          <Icon name="moon" class="vp-theme-icon vp-theme-icon-moon" />
          <Icon name="sun" class="vp-theme-icon vp-theme-icon-sun" />
        </button>
        <button
          type="button"
          id="vpNavHamburger"
          class="vp-nav-hamburger"
          aria-label="Toggle navigation menu"
          aria-controls="vpMobileNavPanel"
          aria-expanded="false"
        >
          <span class="vp-hamburger-line"></span>
          <span class="vp-hamburger-line"></span>
          <span class="vp-hamburger-line"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav panel (solid opaque background, opens below header) -->
  <div id="vpMobileNavPanel" class="vp-mobile-nav-panel" aria-hidden="true">
    <nav class="vp-mobile-nav-links" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a
          class={`vp-mobile-nav-link ${isActive(link.link) ? 'active' : ''}`}
          href={link.link}
          target={link.link.startsWith('http') ? '_blank' : undefined}
          rel={link.link.startsWith('http') ? 'noreferrer' : undefined}
        >
          <span class="vp-mobile-nav-link-content">
            <Icon name={link.icon} class="vp-mobile-nav-link-icon" />
            <span>{link.text}</span>
          </span>
        </a>
      ))}
    </nav>
  </div>

  <!-- Overlay: darkens content when mobile menu is open; click to close -->
  <div id="vpNavOverlay" class="vp-nav-overlay" aria-hidden="true"></div>
</header>
