---
import { isToolboxRoute } from '../scripts/toolbox-routes';

interface NavLink {
  text: string;
  link: string;
  icon?: string;
}

export interface Props {
  title?: string;
  icon?: string;
  links?: NavLink[];
}

const { title = 'Interneto', icon = '📚', links = [] } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const pathname = Astro.url.pathname;

const defaultLinks: NavLink[] = [
  { text: '📚 Categories', link: `${BASE}categories/` },
  { text: '🗺️ Map of Links', link: `${BASE}map/` },
  { text: '🧰 Toolbox Installer', link: `${BASE}toolbox-installer/` },
  { text: '📑 Posts', link: `${BASE}posts/` },
  { text: 'ℹ️ About', link: `${BASE}about/` },
];

const navLinks = links.length > 0 ? links : defaultLinks;

const isActive = (link: string) => {
  if (link === `${BASE}toolbox-installer/`) {
    return isToolboxRoute(pathname, BASE);
  }
  if (link === `${BASE}` || link === '/') {
    return pathname === BASE || pathname === '/';
  }
  return pathname.startsWith(link);
};
---

<header class="vp-nav">
  <div class="vp-nav-bar vp-nav-bar-home top">
    <div class="vp-nav-wrapper">
      <div class="vp-nav-container">
        <div class="vp-nav-title">
          <a class="vp-nav-brand" href={`${BASE}`}>
            <img src={`${BASE}icon.png`} alt="Interneto" class="vp-nav-icon-img" />
            <span class="vp-nav-brand-text">{title}</span>
          </a>
        </div>
        <div class="vp-nav-content">
          <div class="vp-nav-body">
            <nav class="vp-nav-menu" aria-label="Main Navigation">
              {navLinks.map((link) => (
                <a 
                  class={`vp-nav-menu-link ${isActive(link.link) ? 'active' : ''}`}
                  href={link.link}
                  target={link.link.startsWith('http') ? '_blank' : undefined}
                  rel={link.link.startsWith('http') ? 'noreferrer' : undefined}
                >
                  {link.text}
                </a>
              ))}
            </nav>
          </div>
          <div class="vp-nav-actions">
            <button type="button" id="themeToggle" data-theme-toggle class="vp-theme-toggle" aria-label="Switch theme" title="Theme">
              <span class="vp-icon-moon">🌙</span>
              <span class="vp-icon-sun">☀️</span>
            </button>
          </div>
        </div>
        <button
          type="button"
          id="vpNavHamburger"
          class="vp-nav-hamburger"
          aria-label="Toggle mobile menu"
          aria-controls="vpMobileNavPanel"
          aria-expanded="false"
        >
          <span class="vp-hamburger-line"></span>
          <span class="vp-hamburger-line"></span>
          <span class="vp-hamburger-line"></span>
        </button>
      </div>
    </div>
    <div id="vpMobileNavPanel" class="vp-mobile-nav-panel" aria-hidden="true">
      <nav class="vp-mobile-nav-links" aria-label="Mobile Navigation">
        {navLinks.map((link) => (
          <a
            class={`vp-mobile-nav-link ${isActive(link.link) ? 'active' : ''}`}
            href={link.link}
            target={link.link.startsWith('http') ? '_blank' : undefined}
            rel={link.link.startsWith('http') ? 'noreferrer' : undefined}
          >
            {link.text}
          </a>
        ))}
      </nav>
      <div class="vp-mobile-nav-theme-row">
        <span class="vp-mobile-nav-theme-label">Theme</span>
        <button type="button" data-theme-toggle class="vp-theme-toggle vp-theme-toggle-mobile" aria-label="Switch theme" title="Theme">
          <span class="vp-icon-moon">🌙</span>
          <span class="vp-icon-sun">☀️</span>
        </button>
      </div>
    </div>
    <div class="vp-nav-divider"></div>
  </div>
</header>
