---
interface Props {
  title?: string;
  tagline?: string;
  image?: {
    src: string;
    alt: string;
  };
  actions?: Array<{
    theme?: 'brand' | 'alt';
    text: string;
    link: string;
  }>;
}

const {
  title = 'Interneto',
  tagline = 'Rediscover the Internet!',
  image,
  actions = []
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section class="vp-hero has-image">
  <div class="vp-hero-container">
    <div class="vp-hero-main">
      <h1 class="vp-hero-title">
        <span class="vp-hero-title-text clip">{title}</span>
      </h1>
      <p class="vp-hero-tagline">{tagline}</p>
      
      {actions.length > 0 && (
        <div class="vp-hero-actions">
          {actions.map((action) => (
            <a
              class={`vp-hero-action vp-button vp-button-${action.theme || 'brand'}`}
              href={action.link}
            >
              {action.text}
            </a>
          ))}
        </div>
      )}
    </div>

    {image && (
      <div class="vp-hero-image">
        <div class="vp-hero-image-container">
          <div class="vp-hero-image-bg"></div>
          <img class="vp-hero-image-src" src={image.src} alt={image.alt} />
        </div>
      </div>
    )}
  </div>
</section>
