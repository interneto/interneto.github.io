---
import Icon from './Icon.astro';
import type { IconName } from './Icon.astro';

interface SidebarItem {
  text: string;
  href: string;
  icon?: IconName;
  isActive: boolean;
}

interface SidebarSection {
  title: string;
  items: SidebarItem[];
}

export interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const isPathActive = (link: string): boolean => {
  return currentPath.startsWith(link) || currentPath === link;
};

// Build category items
const categoryItems: SidebarItem[] = [
  { text: '🏢 By Company', href: `${BASE}categories/by-company/`, isActive: isPathActive(`${BASE}categories/by-company/`) },
  { text: '🐧 Operating System', href: `${BASE}categories/os/`, isActive: isPathActive(`${BASE}categories/os/`) },
  { text: '🧰 AI Tools and Services', href: `${BASE}categories/ai-tools-and-services/`, isActive: isPathActive(`${BASE}categories/ai-tools-and-services/`) },
  { text: '⌨️ Development', href: `${BASE}categories/dev/`, isActive: isPathActive(`${BASE}categories/dev/`) },
  { text: '🎓 Education', href: `${BASE}categories/education/`, isActive: isPathActive(`${BASE}categories/education/`) },
  { text: '📁 File Management', href: `${BASE}categories/file-management/`, isActive: isPathActive(`${BASE}categories/file-management/`) },
  { text: '💰 Financial Assets', href: `${BASE}categories/financial-assets/`, isActive: isPathActive(`${BASE}categories/financial-assets/`) },
  { text: '🎮 Gaming', href: `${BASE}categories/gaming/`, isActive: isPathActive(`${BASE}categories/gaming/`) },
  { text: '❤️ Health and Fitness', href: `${BASE}categories/health-and-fitness/`, isActive: isPathActive(`${BASE}categories/health-and-fitness/`) },
  { text: '🏠 Home and Family', href: `${BASE}categories/home-and-family/`, isActive: isPathActive(`${BASE}categories/home-and-family/`) },
  { text: '☎️ Intercommunication', href: `${BASE}categories/intercomm/`, isActive: isPathActive(`${BASE}categories/intercomm/`) },
  { text: '📺 Multimedia', href: `${BASE}categories/multimedia/`, isActive: isPathActive(`${BASE}categories/multimedia/`) },
  { text: '📰 News and Media', href: `${BASE}categories/news-media/`, isActive: isPathActive(`${BASE}categories/news-media/`) },
  { text: '💼 Office and Productivity', href: `${BASE}categories/office-and-productivity/`, isActive: isPathActive(`${BASE}categories/office-and-productivity/`) },
  { text: '🌐 Online Services', href: `${BASE}categories/online-services/`, isActive: isPathActive(`${BASE}categories/online-services/`) },
  { text: '🛡️ Security and Privacy', href: `${BASE}categories/security-and-privacy/`, isActive: isPathActive(`${BASE}categories/security-and-privacy/`) },
  { text: '💻 System Administration', href: `${BASE}categories/sys-admin/`, isActive: isPathActive(`${BASE}categories/sys-admin/`) },
  { text: '🕐 Time', href: `${BASE}categories/time/`, isActive: isPathActive(`${BASE}categories/time/`) },
  { text: '🌎 Travel and Location', href: `${BASE}categories/travel-and-location/`, isActive: isPathActive(`${BASE}categories/travel-and-location/`) },
  { text: '🛠️ Utility', href: `${BASE}categories/utility/`, isActive: isPathActive(`${BASE}categories/utility/`) },
];

const postSections: SidebarSection[] = [
  {
    title: 'Comparing',
    items: [
      { text: 'AI Coding Tools', href: `${BASE}posts/ai-coding-tools/`, isActive: isPathActive(`${BASE}posts/ai-coding-tools/`) },
      { text: 'Bookmark Managers', href: `${BASE}posts/bookmark-managers/`, isActive: isPathActive(`${BASE}posts/bookmark-managers/`) },
      { text: 'Linux Distributions', href: `${BASE}posts/linux-distros/`, isActive: isPathActive(`${BASE}posts/linux-distros/`) },
    ]
  },
  {
    title: 'How-To',
    items: [
      { text: 'How To Categorize Links', href: `${BASE}posts/how-to-categorize-links/`, isActive: isPathActive(`${BASE}posts/how-to-categorize-links/`) },
      { text: 'How Files Are Transferred', href: `${BASE}posts/file-sync/`, isActive: isPathActive(`${BASE}posts/file-sync/`) },
    ]
  },
  {
    title: 'Articles',
    items: [
      { text: 'Cybersecurity Vulnerabilities', href: `${BASE}posts/cybersecurity-vulnerabilities/`, isActive: isPathActive(`${BASE}posts/cybersecurity-vulnerabilities/`) },
      { text: 'Operating System Layer Stack', href: `${BASE}posts/os-layer-stack/`, isActive: isPathActive(`${BASE}posts/os-layer-stack/`) },
      { text: 'What Is Information?', href: `${BASE}posts/what-is-info/`, isActive: isPathActive(`${BASE}posts/what-is-info/`) },
      { text: 'History of Computing Timeline', href: `${BASE}posts/history-of-computing/`, isActive: isPathActive(`${BASE}posts/history-of-computing/`) },
    ]
  },
];

const mapItems: SidebarItem[] = [
  { text: 'Open Dashboard', href: `${BASE}map/`, icon: 'map', isActive: isPathActive(`${BASE}map/`) },
  { text: 'Classic View', href: `${BASE}map/?view=classic`, icon: 'map', isActive: false },
  { text: 'Semantic View', href: `${BASE}map/?view=semantic`, icon: 'map', isActive: false },
  { text: 'Geo View', href: `${BASE}map/?view=geo`, icon: 'map', isActive: false },
  { text: 'Blog Posts', href: `${BASE}posts/`, icon: 'posts', isActive: false },
  { text: 'Categories', href: `${BASE}categories/`, icon: 'categories', isActive: false },
];

// Determine which sidebar to show
const showPostsSidebar = currentPath.includes('/posts');
const showMapSidebar = currentPath.includes('/map');
const showCategoryFavoritesToggle = currentPath.includes('/categories');
const showCategorySidebar = !showPostsSidebar && !showMapSidebar;
const items = showPostsSidebar ? [] : showMapSidebar ? mapItems : categoryItems;
const title = showPostsSidebar ? 'Posts' : showMapSidebar ? 'Link Dashboard' : 'Categories';
---

<aside id="vpSidebar" class="vp-sidebar" aria-hidden="false">
  <div class="vp-sidebar-content">
    <nav class="vp-sidebar-nav">
      <div class="vp-sidebar-title">{title}</div>
      {showCategorySidebar && (
        <div class="vp-sidebar-search-wrap">
          <input
            id="categorySidebarSearch"
            class="vp-sidebar-search-input"
            type="search"
            placeholder="Search categories"
            autocomplete="off"
            aria-label="Search categories"
          />
        </div>
      )}
      {showCategoryFavoritesToggle && (
        <button type="button" class="vp-sidebar-toggle-btn" id="categoryFavoritesToggle" aria-pressed="false">
          ☆ Favorite Links
        </button>
      )}
      {showPostsSidebar ? (
        postSections.map((section) => (
          <div class="vp-sidebar-section">
            <div class="vp-sidebar-section-title">{section.title}</div>
            <div class="vp-sidebar-items">
              {section.items.map((item) => (
                <a
                  class={`vp-sidebar-item-link ${item.isActive ? 'active' : ''}`}
                  href={item.href}
                >
                  <span class="vp-sidebar-item-content">
                    <Icon name={item.icon ?? 'posts'} class="vp-sidebar-link-icon" />
                    <span>{item.text}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))
      ) : (
        <div class="vp-sidebar-items">
          {items.map((item) => (
            <a
              class={`vp-sidebar-item-link ${item.isActive ? 'active' : ''}`}
              href={item.href}
            >
              <span class="vp-sidebar-item-content">
                {item.icon && <Icon name={item.icon} class="vp-sidebar-link-icon" />}
                <span>{item.text}</span>
              </span>
            </a>
          ))}
        </div>
      )}
    </nav>
  </div>
</aside>

<script>
  const CATEGORY_FAVORITES_STORAGE_KEY = 'interneto.category-favorites-only';
  const favoritesToggle = document.getElementById('categoryFavoritesToggle');
  const categorySearchInput = document.getElementById('categorySidebarSearch');

  if (categorySearchInput instanceof HTMLInputElement) {
    const categoryLinks = Array.from(document.querySelectorAll('.vp-sidebar-items .vp-sidebar-item-link'));
    const normalize = (value) => value.trim().toLowerCase();

    const applyCategorySidebarFilter = (query) => {
      const normalizedQuery = normalize(query);

      categoryLinks.forEach((link) => {
        const label = normalize(link.textContent || '');
        const visible = normalizedQuery === '' || label.includes(normalizedQuery);
        link.classList.toggle('vp-sidebar-search-hidden', !visible);
      });
    };

    categorySearchInput.addEventListener('input', () => {
      applyCategorySidebarFilter(categorySearchInput.value);
    });
  }

  if (favoritesToggle) {
    const proseRoot = document.querySelector('.vp-prose');
    const listItems = proseRoot ? Array.from(proseRoot.querySelectorAll('li')) : [];
    const headings = proseRoot
      ? Array.from(proseRoot.querySelectorAll('h2, h3, h4, h5, h6'))
      : [];
    const lists = proseRoot
      ? Array.from(proseRoot.querySelectorAll('ul, ol'))
      : [];

    const isFavoriteItem = (item) => item.textContent?.trim().startsWith('⭐') ?? false;
    const setToggleState = (enabled) => {
      favoritesToggle.classList.toggle('is-active', enabled);
      favoritesToggle.setAttribute('aria-pressed', enabled ? 'true' : 'false');
      favoritesToggle.textContent = enabled ? '★ Favorite Links' : '☆ Favorite Links';
    };

    const getHeadingLevel = (heading) => Number.parseInt(heading.tagName.slice(1), 10);

    const syncFavoritesFilter = (enabled) => {
      listItems.forEach((item) => {
        item.classList.toggle('vp-favorite-hidden', enabled && !isFavoriteItem(item));
      });

      lists.forEach((list) => {
        const visibleItems = Array.from(list.children).some((child) => !child.classList.contains('vp-favorite-hidden'));
        list.classList.toggle('vp-favorite-hidden', enabled && !visibleItems);
      });

      headings.forEach((heading) => {
        const currentLevel = getHeadingLevel(heading);
        let sibling = heading.nextElementSibling;
        let hasVisibleContent = false;

        while (sibling) {
          if (/^H[2-6]$/.test(sibling.tagName) && getHeadingLevel(sibling) <= currentLevel) {
            break;
          }
          if (!sibling.classList.contains('vp-favorite-hidden')) {
            hasVisibleContent = true;
            break;
          }
          sibling = sibling.nextElementSibling;
        }

        heading.classList.toggle('vp-favorite-hidden', enabled && !hasVisibleContent);
      });
    };

    const storedValue = localStorage.getItem(CATEGORY_FAVORITES_STORAGE_KEY) === 'true';
    setToggleState(storedValue);
    syncFavoritesFilter(storedValue);

    favoritesToggle.addEventListener('click', () => {
      const nextValue = favoritesToggle.getAttribute('aria-pressed') !== 'true';
      localStorage.setItem(CATEGORY_FAVORITES_STORAGE_KEY, String(nextValue));
      setToggleState(nextValue);
      syncFavoritesFilter(nextValue);
    });
  }
</script>
