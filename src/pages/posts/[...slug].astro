---
import { getCollection, render } from 'astro:content';
import VPLayout from '../../layouts/VPLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/i, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const pageTitle = entry.data.title ?? entry.id;
const hasLeadingMarkdownTitle = /^\s*#\s+/.test(entry.body ?? '');
---

<VPLayout title={pageTitle} hasSidebar={true} extraStyles={['styles/posts-page.css']}>
  <div class="vp-post-wrapper">
    <nav class="vp-breadcrumb" aria-label="Breadcrumb">
      <a href={`${BASE}`}>Home</a>
      <span class="vp-breadcrumb-sep">›</span>
      <a href={`${BASE}posts/`}>Posts</a>
      <span class="vp-breadcrumb-sep">›</span>
      <span>{pageTitle}</span>
    </nav>

    <article class="vp-post-content">
      {!hasLeadingMarkdownTitle && (
        <header class="vp-post-header">
          <h1>{pageTitle}</h1>
          {entry.data.description && <p class="vp-post-lead">{entry.data.description}</p>}
        </header>
      )}
      <div class="vp-prose">
        <Content />
      </div>
    </article>
  </div>
</VPLayout>
