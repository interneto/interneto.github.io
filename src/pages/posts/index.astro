---
import { getCollection } from 'astro:content';
import VPLayout from '../../layouts/VPLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const cleanSlug = (id: string) => id.replace(/\.md$/i, '');
const sectionBySlug: Record<string, 'Comparing' | 'How-To' | 'Articles'> = {
  'ai-coding-tools': 'Comparing',
  'bookmark-managers': 'Comparing',
  'linux-distros': 'Comparing',
  'how-to-categorize-links': 'How-To',
  'file-sync': 'How-To',
  'cybersecurity-vulnerabilities': 'Articles',
  'os-layer-stack': 'Articles',
  'what-is-info': 'Articles',
};

const posts = (await getCollection('posts'))
  .filter((entry) => cleanSlug(entry.id) !== 'index')
  .sort((a, b) => a.id.localeCompare(b.id));

const sectionOrder: Array<'Comparing' | 'How-To' | 'Articles'> = ['Comparing', 'How-To', 'Articles'];

const groupedPosts = sectionOrder.map((section) => ({
  section,
  items: posts.filter((entry) => {
    const slug = cleanSlug(entry.id);
    return (sectionBySlug[slug] ?? 'Articles') === section;
  })
}));
---

<VPLayout title="📑 Posts" hasSidebar={true}>
  <div class="vp-content-wrapper">
    <header class="vp-content-header">
      <h1>Blog Posts</h1>
      <p class="vp-content-subtitle">Curated articles, guides, and insights about internet tools and organization.</p>
    </header>

    {groupedPosts.map((group) => (
      <section class="vp-posts-section" aria-label={`${group.section} posts`}>
        <h2 class="vp-posts-section-title">{group.section}</h2>
        <div class="vp-posts-grid">
          {group.items.map((entry) => (
            <article class="vp-post-card">
              <h3 class="vp-post-title">
                <a href={`${BASE}posts/${cleanSlug(entry.id)}/`}>{entry.data.title ?? cleanSlug(entry.id)}</a>
              </h3>
              {entry.data.description && <p class="vp-post-description">{entry.data.description}</p>}
              <a href={`${BASE}posts/${cleanSlug(entry.id)}/`} class="vp-post-link">Read more →</a>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</VPLayout>

<style>
  .vp-content-wrapper {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 32px;
  }

  .vp-content-header {
    margin-bottom: 48px;
  }

  .vp-posts-section {
    margin-bottom: 44px;
  }

  .vp-posts-section:last-child {
    margin-bottom: 0;
  }

  .vp-posts-section-title {
    margin: 0 0 18px;
    font-size: 1.25em;
    color: var(--vp-c-text-1);
    letter-spacing: 0.02em;
  }

  .vp-content-header h1 {
    font-size: 2.5em;
    font-weight: 700;
    color: var(--vp-c-text-1);
    margin-bottom: 16px;
  }

  .vp-content-subtitle {
    font-size: 1.1em;
    color: var(--vp-c-text-2);
    line-height: 1.6;
  }

  .vp-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .vp-post-card {
    padding: 24px;
    border: 1px solid var(--vp-c-divider);
    border-radius: 8px;
    background-color: var(--vp-c-bg-alt);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .vp-post-card:hover {
    background-color: var(--vp-c-bg);
    border-color: var(--vp-c-brand-1);
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(123, 197, 228, 0.15);
  }

  .vp-post-title {
    font-size: 1.3em;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .vp-post-title a {
    color: var(--vp-c-text-1);
    text-decoration: none;
  }

  .vp-post-title a:hover {
    color: var(--vp-c-brand-1);
  }

  .vp-post-description {
    color: var(--vp-c-text-2);
    font-size: 0.95em;
    margin-bottom: 16px;
    flex-grow: 1;
    line-height: 1.6;
  }

  .vp-post-link {
    color: var(--vp-c-brand-1);
    font-weight: 500;
    text-decoration: none;
    font-size: 0.9em;
    display: inline-block;
    transition: all 0.2s;
  }

  .vp-post-link:hover {
    color: var(--vp-c-brand-2);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .vp-content-wrapper {
      padding: 32px 16px;
    }

    .vp-content-header h1 {
      font-size: 1.875em;
    }

    .vp-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
