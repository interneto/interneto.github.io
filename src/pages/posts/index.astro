---
import { getCollection } from 'astro:content';
import VPLayout from '../../layouts/VPLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const cleanSlug = (id: string) => id.replace(/\.md$/i, '');
const sectionBySlug: Record<string, 'Comparing' | 'How-To' | 'Articles'> = {
  'ai-coding-tools': 'Comparing',
  'bookmark-managers': 'Comparing',
  'linux-distros': 'Comparing',
  'how-to-categorize-links': 'How-To',
  'file-sync': 'How-To',
  'cybersecurity-vulnerabilities': 'Articles',
  'os-layer-stack': 'Articles',
  'what-is-info': 'Articles',
  'history-of-computing': 'Articles',
};

const posts = (await getCollection('posts'))
  .filter((entry) => cleanSlug(entry.id) !== 'index')
  .sort((a, b) => a.id.localeCompare(b.id));

const sectionOrder: Array<'Comparing' | 'How-To' | 'Articles'> = ['Comparing', 'How-To', 'Articles'];

const groupedPosts = sectionOrder.map((section) => ({
  section,
  items: posts.filter((entry) => {
    const slug = cleanSlug(entry.id);
    return (sectionBySlug[slug] ?? 'Articles') === section;
  })
}));
---

<VPLayout title="📑 Posts" hasSidebar={true} extraStyles={['styles/posts-index.css']}>
  <div class="vp-content-wrapper">
    <header class="vp-content-header">
      <h1>Blog Posts</h1>
      <p class="vp-content-subtitle">Curated articles, guides, and insights about internet tools and organization.</p>
    </header>

    {groupedPosts.map((group) => (
      <section class="vp-posts-section" aria-label={`${group.section} posts`}>
        <h2 class="vp-posts-section-title">{group.section}</h2>
        <div class="vp-posts-grid">
          {group.items.map((entry) => (
            <article class="vp-post-card">
              <h3 class="vp-post-title">
                <a href={`${BASE}posts/${cleanSlug(entry.id)}/`}>{entry.data.title ?? cleanSlug(entry.id)}</a>
              </h3>
              {entry.data.description && <p class="vp-post-description">{entry.data.description}</p>}
              <a href={`${BASE}posts/${cleanSlug(entry.id)}/`} class="vp-post-link">Read more →</a>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</VPLayout>
