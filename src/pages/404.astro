---
import VPLayout from '../layouts/VPLayout.astro';
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<VPLayout title="404 – Page Not Found" description="The page you are looking for does not exist." hasSidebar={false}>
  <section class="not-found">
    <p class="not-found-code">404</p>
    <h1>Page not found</h1>
    <p class="not-found-desc">The page you are looking for doesn't exist or has been moved.</p>
    <nav class="not-found-links" aria-label="Return navigation">
      <a href={`${BASE}`}>Home</a>
      <a href={`${BASE}categories/`}>Categories</a>
      <a href={`${BASE}toolbox/`}>Toolbox</a>
      <a href={`${BASE}posts/`}>Posts</a>
      <a href={`${BASE}map/`}>Map</a>
    </nav>
  </section>
</VPLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 1rem;
    padding: 2rem;
  }
  .not-found-code {
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 800;
    line-height: 1;
    margin: 0;
    color: var(--primary-color);
    opacity: 0.25;
  }
  .not-found h1 {
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
  }
  .not-found-desc {
    margin: 0;
    color: var(--text-secondary);
    max-width: 36ch;
  }
  .not-found-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .not-found-links a {
    padding: 0.5rem 1.125rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    background: var(--card-background);
    transition: border-color 0.15s, color 0.15s;
  }
  .not-found-links a:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }
</style>
