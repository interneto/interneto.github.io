---
import VPLayout from '../layouts/VPLayout.astro';
import VPHero from '../components/VPHero.astro';
import VPFeatures from '../components/VPFeatures.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const homeSections = [
  {
    icon: '📚',
    title: 'Categories',
    details: 'Browse all curated categories in one place',
    link: `${BASE}categories/`,
  },
  {
    icon: '📑',
    title: 'Blog Posts',
    details: 'Curated articles, comparisons, and guides',
    link: `${BASE}posts/`,
  },
  {
    icon: '🗺️',
    title: 'Bookmark Map',
    details: 'Open the interactive link dashboard',
    link: `${BASE}map/`,
  },
];
---

<VPLayout title="Interneto" hideSidebar hideFooter={false}>
  <VPHero 
    title="Interneto" 
    tagline="Rediscover the Internet! 🌐"
    image={{
      src: '/icon.png',
      alt: 'Interneto Icon'
    }}
    actions={[
      { theme: 'brand', text: 'Explore Categories', link: `${BASE}categories/` },
      { theme: 'alt', text: 'Read Blog', link: `${BASE}posts/` }
    ]}
  />
  <VPFeatures 
    title="Explore"
    features={homeSections}
  />

  <section class="vp-home-footer">
    <div class="vp-home-footer-content">
      <p>Made with ❤️ by Interneto • <a href="https://github.com/interneto">GitHub</a> • <a href="https://interneto.raindrop.page/">Raindrop.io</a> • <a href="https://twitter.com/internetoOK">X/Twitter</a></p>
    </div>
  </section>
</VPLayout>

<style>
  .vp-home-footer {
    padding: 64px 32px;
    background-color: var(--vp-c-bg-alt);
    border-top: 1px solid var(--vp-c-divider);
    text-align: center;
  }

  .vp-home-footer-content {
    max-width: 1280px;
    margin: 0 auto;
    color: var(--vp-c-text-2);
    font-size: 14px;
  }

  .vp-home-footer-content a {
    color: var(--vp-c-brand-1);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.25s;
  }

  .vp-home-footer-content a:hover {
    opacity: 0.7;
  }
</style>
