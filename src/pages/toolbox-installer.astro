---
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const target = `${BASE}toolbox/`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <title>Redirecting to Toolbox…</title>
</head>
<body>
  <p>Redirecting to <a href={target}>Toolbox</a>…</p>
</body>
</html>
