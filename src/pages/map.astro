---
import VPLayout from '../layouts/VPLayout.astro';
---

<VPLayout title="Link Dashboard" hasSidebar={false} hideFooter={true}>
  <section class="map-page-shell">
    <div id="bookmark-dashboard-root"></div>
  </section>

  <script>
    import '../features/bookmark-dashboard/main';
  </script>
</VPLayout>

<style>
  .map-page-shell {
    height: calc(100dvh - 61px);
    overflow: hidden;
  }

  #bookmark-dashboard-root {
    height: 100%;
    min-height: 0;
  }
</style>
