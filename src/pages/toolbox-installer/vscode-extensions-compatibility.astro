---
import CompatibilityTablePage from '../../components/CompatibilityTablePage.astro';
---
<CompatibilityTablePage
  title="VS Code Extensions Table"
  heading="🧩 VS Code Extensions Compatibility"
  subtitle="Installed extension list and package identifiers for command generation."
  installerHref="vscode"
  installerLabel="Go to Installer"
  searchPlaceholder="Search extension name, package name, or category"
  showFilterChips={true}
  filterAriaLabel="Filter by extension category"
  pageNote="Search, sort, and filter extensions by category with the same software-table pattern used on desktop."
>
  <div class="table-container">
    <table id="packagesTable">
      <thead id="tableHead"></thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
  <div class="stats" id="statsContainer"></div>
</CompatibilityTablePage>

<script>
import '../../scripts/software-table-pages.ts';
</script>
