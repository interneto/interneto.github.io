---
import ToolboxInstallerSection from '../../components/ToolboxInstallerSection.astro';
import ToolboxResultsContainer from '../../components/ToolboxResultsContainer.astro';
const options = [
  { value: 'loadFavorites', label: '✨ My Favorites' },
  { value: 'importPackages', label: '📥 Import Extensions (JSON)' },
  { value: 'exportPackages', label: '📤 Export Extensions (JSON)' },
];
---
<ToolboxInstallerSection
  title="VS Code Installer"
  heading="VS Code Installer"
  info="Browse curated VS Code extensions organized by category. Select, import, export, and mark favorites to build your ideal editor setup."
  searchPlaceholder="Search by extension name"
  options={options}
>
  <ToolboxResultsContainer slot="content" id="extensionsCategories" />

</ToolboxInstallerSection>

<script>
import '../../scripts/packages-table.ts';
</script>
