---
import CompatibilityTablePage from '../../components/CompatibilityTablePage.astro';
import softwareTablePagesScriptUrl from '../../scripts/software-table-pages.ts?url';
---
<CompatibilityTablePage
  title="Browser Extensions Table"
  heading="🧩 Browser Extensions Compatibility"
  subtitle="Extension list and store links for Firefox and Chromium-based browsers."
  installerHref="browser"
  installerLabel="Go to Installer"
  searchPlaceholder="Search extension name, id, or category"
  showFilterChips={true}
  filterAriaLabel="Filter by category"
>
  <div class="table-container">
    <table id="packagesTable">
      <thead id="tableHead"></thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
  <div class="stats" id="statsContainer"></div>
  <script slot="script" type="module" src={softwareTablePagesScriptUrl}></script>
</CompatibilityTablePage>
