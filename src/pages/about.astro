---
import { getCollection } from 'astro:content';
import VPLayout from '../layouts/VPLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const docs = await getCollection('docs');
const entry = docs.find((item) => item.id.replace(/\.md$/i, '') === 'about');

if (!entry) {
  throw new Error('About content not found.');
}

const { Content } = await entry.render();
const pageTitle = entry.data.title ?? 'About';
---

<VPLayout title={pageTitle} hasSidebar={false} extraStyles={['styles/about-page.css']}>
  <div class="vp-about-wrapper">
    <nav class="vp-breadcrumb" aria-label="Breadcrumb">
      <a href={`${BASE}`}>Home</a>
      <span class="vp-breadcrumb-sep">›</span>
      <span>{pageTitle}</span>
    </nav>

    <article class="vp-about-content">
      <header class="vp-about-header">
        <h1>{pageTitle}</h1>
        {entry.data.description && <p class="vp-about-lead">{entry.data.description}</p>}
      </header>
      <div class="vp-prose">
        <Content />
      </div>
    </article>
  </div>
</VPLayout>